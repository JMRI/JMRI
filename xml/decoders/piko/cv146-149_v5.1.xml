		<label xml:lang="de">Alternative Höchstgeschwindigkeit rückwärts (CV 148)</label>
		<tooltip>0 - 255</tooltip>
		<tooltip xml:lang="de">0 - 255</tooltip>
	</variable>
	<variable item="Alt_max_speed_fkey" CV="149" default="0">
		<xi:include href="http://jmri.org/xml/decoders/piko/enumFunctionChoiceF68Off255.xml"/>
		<label>Alternative maximum speed Function Key (CV 149)</label>
		<label xml:lang="de">Funktionstaste für alternative Höchstgeschwindigkeit (CV 149)</label>
		<tooltip>(0 - 68) 255 = Off</tooltip>
		<tooltip xml:lang="de">F1 - F68 / 255 = Aus</tooltip>
	</variable>
