	<variable item="Alt_max_speed_forward" CV="147" default="0">
		<decVal max="255"/>
		<label>Alternative maximum speed forward (CV 147)</label>
		<label xml:lang="de">Alternative Höchstgeschwindigkeit vorwärts (CV 147)</label>
		<tooltip>0 - 255</tooltip>
		<tooltip xml:lang="de">0 - 255</tooltip>
	</variable>
	<variable item="Alt_max_speed_backward" CV="148" default="0">
		<decVal max="255"/>
